{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://starterkit.aws/schemas/catalog-schema.json",
  "title": "Starter Kit Catalog Index",
  "description": "The machine-readable Catalog: the only output space APEX instantiates from (ADR-0003). Every item is semver-versioned (criteria #7: 0.x = early adopters, 1.0+ = majority).",
  "type": "object",
  "required": ["apiVersion", "kind", "items"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": { "const": "starterkit.aws/v1alpha1" },
    "kind": { "const": "Catalog" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/catalogItem" }
    }
  },
  "$defs": {
    "catalogItem": {
      "type": "object",
      "required": ["name", "kind", "version", "description", "path"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Kebab-case item identifier, unique within the catalog"
        },
        "kind": {
          "enum": ["kro-type", "app-template"],
          "description": "kro-type: a ResourceGraphDefinition instance template; app-template: a repo skeleton"
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(-[0-9A-Za-z.-]+)?$",
          "description": "Semver. 0.x signals early-adopter maturity (ADR criteria #7)."
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "description": "One-line description APEX shows in catalog-browse"
        },
        "path": {
          "type": "string",
          "pattern": "^(types|templates)/[a-z][a-z0-9-]*",
          "description": "Artifact source location, relative to platform/catalog/"
        },
        "parameters": {
          "type": "array",
          "description": "The item's full parameter surface — APEX may collect ONLY these (ADR-0003)",
          "items": { "$ref": "#/$defs/parameter" }
        }
      }
    },
    "parameter": {
      "type": "object",
      "required": ["name", "type", "description"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "type": { "enum": ["string", "integer", "boolean", "enum"] },
        "description": { "type": "string", "minLength": 5 },
        "required": { "type": "boolean", "default": false },
        "default": {},
        "values": {
          "type": "array",
          "description": "Allowed values when type is enum",
          "items": { "type": "string" }
        },
        "pattern": {
          "type": "string",
          "description": "Validation regex for string parameters"
        }
      }
    }
  }
}
